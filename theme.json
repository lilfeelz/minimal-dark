  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#888888", "fontStyle": "italic" } },

    { "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#f1fa8c" } },

    { "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#bd93f9" } },

    { "scope": ["keyword", "keyword.control", "keyword.operator", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff79c6" } },

    { "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": { "foreground": "#50fa7b" } },

    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#8be9fd", "fontStyle": "italic" } },

    { "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#ffffff" } },

    { "scope": ["variable.parameter"],
      "settings": { "foreground": "#ffb86c", "fontStyle": "italic" } },

    { "scope": ["entity.name.tag"],
      "settings": { "foreground": "#ff79c6" } },

    { "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#50fa7b" } },

    { "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#ff79c6" } },

    { "scope": ["keyword.control.import", "keyword.control.from"],
      "settings": { "foreground": "#ff79c6" } },

    { "scope": ["comment.todo", "meta.embedded"],
      "settings": { "foreground": "#000000", "background": "#ff92df", "fontStyle": "bold" } },

    { "scope": ["variable.other.terraform"],
      "settings": { "foreground": "#8be9fd" } },

    { "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#8be9fd" } },

    { "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#50fa7b", "fontStyle": "italic" } }
  ]
}
